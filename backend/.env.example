# ===== Banco de dados =====
# Dev local: deixe como SQLite. Produção: Postgres/Neon.
# Cada projeto usa seu PRÓPRIO schema (DB_SCHEMA) dentro do mesmo banco Neon.
DATABASE_URL=sqlite:///./wdocar.db
# Produção (exemplo):
# DATABASE_URL=postgresql://USUARIO:SENHA@ep-xxxx-pooler.REGIAO.aws.neon.tech/neondb?sslmode=require
DB_SCHEMA=giro_app

# ===== Segurança =====
ENV=development                       # em produção: production (exige JWT_SECRET_KEY)
JWT_SECRET_KEY=generate-a-secure-random-string-here

# ===== CORS / URLs =====
# Origem(ns) do frontend permitidas (separadas por vírgula, sem barra no final).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
# Usada nos links de recuperação de senha por email.
FRONTEND_URL=http://localhost:3000

# ===== Email (Resend) — opcional =====
RESEND_API_KEY=
EMAIL_FROM=GiroCerto <onboarding@resend.dev>

# ===== Web Push (VAPID) — opcional =====
VAPID_CLAIM_EMAIL=mailto:admin@girocerto.com

# ===== Agendador / backups =====
DISABLE_SCHEDULER=                    # =1 desliga os jobs (backup diário, checagens)
OS_ATRASADA_DIAS=7
MAX_BACKUPS=14
